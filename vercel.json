{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/public",
  "framework": null,
  "headers": [
    {
      "source": "/embed",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ],
  "routes": [
    { "src": "/embed", "dest": "/index.html", "headers": { "Content-Security-Policy": "frame-ancestors *" } },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/room-planner", "dest": "/room-planner.html" },
    { "src": "/kitchen-planner", "dest": "/kitchen-planner.html" },
    { "src": "/bathroom-planner", "dest": "/bathroom-planner.html" },
    { "src": "/bedroom-planner", "dest": "/bedroom-planner.html" },
    { "src": "/living-room-planner", "dest": "/living-room-planner.html" },
    { "src": "/floor-plan-maker", "dest": "/floor-plan-maker.html" },
    { "src": "/how-it-works", "dest": "/how-it-works.html" },
    { "src": "/blog", "dest": "/blog/index.html" },
    { "src": "/blog/(.*)", "dest": "/blog/$1.html" },
    { "src": "/(.+\\.(?:png|jpg|jpeg|svg|ico|webp|css|js|woff2?|ttf|json|xml|txt))$", "dest": "/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/app", "dest": "/index.html" },
    { "src": "/app/(.*)", "dest": "/index.html" },
    { "src": "/admin", "dest": "/index.html" },
    { "src": "/get-embed", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
